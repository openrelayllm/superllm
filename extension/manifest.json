{
  "manifest_version": 3,
  "name": "Sub2API Plus Session Capture",
  "version": "0.1.0",
  "description": "Capture supplier browser sessions and report them to Sub2API Plus.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Sub2API Plus Session Capture",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/site-probe.js",
        "src/content/newapi.js",
        "src/content/sub2api.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
