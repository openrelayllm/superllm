{
  "manifest_version": 3,
  "name": "Sub2API Plus Session Capture",
  "version": "0.1.0",
  "description": "Capture supplier browser sessions and report them to Sub2API Plus.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Sub2API Plus Session Capture",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/sub2api.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
