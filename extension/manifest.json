{
  "manifest_version": 3,
  "name": "Sub2API Admin Plus Operator",
  "version": "0.1.0",
  "description": "Execute Admin Plus supplier collection tasks from browser sessions.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Admin Plus Operator",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/parser.js",
        "src/content/sub2api.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
